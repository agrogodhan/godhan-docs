# ============================================================
#  .env  —  Environment Configuration
#  Copy this to .env and fill in your values
# ============================================================

# Server
PORT=3000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://localhost:27017/cattle_collar
# For Atlas: mongodb+srv://user:pass@cluster.mongodb.net/cattle_collar

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# MQTT Broker (AWS IoT or Mosquitto)
MQTT_BROKER_URL=mqtt://localhost:1883
# For AWS IoT: mqtts://your-endpoint.iot.region.amazonaws.com:8883
MQTT_CLIENT_ID=cattle-api-server
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_CA_CERT_PATH=./certs/root-ca.pem
MQTT_CLIENT_CERT_PATH=./certs/server-cert.pem
MQTT_CLIENT_KEY_PATH=./certs/server-key.pem

# Alert thresholds (can override defaults in models)
ALERT_TEMP_FEVER=39.5
ALERT_HR_HIGH=100
ALERT_SPO2_LOW=92
ALERT_RUMINATION_LOW=300
